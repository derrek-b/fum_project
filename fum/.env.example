# FUM Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED FOR LIBRARY INITIALIZATION
# ============================================
# These three keys are passed to initFumLibrary() in src/pages/_app.js.
# Missing any of them will throw a clear startup error — see _app.js.

# CoinGecko API key for token price feeds
# Public tier (unauthenticated) rate-limits at ~10-30 req/min shared IP and
# will silently degrade USD price display under load. Free demo key signup:
# https://www.coingecko.com/en/api/pricing
NEXT_PUBLIC_COINGECKO_API_KEY=your_coingecko_api_key

# Alchemy API key for RPC endpoints
# Used by V3/V4 adapters (AlphaRouter, pool queries) in production and by
# local Hardhat fork testing.
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# The Graph API key for subgraph queries (V4 pool discovery, position lookup, TVL)
# Required whenever V4 flows run in the frontend.
NEXT_PUBLIC_THEGRAPH_API_KEY=your_thegraph_api_key

# ============================================
# REQUIRED FOR DEMO PAGE
# ============================================
# Wallet address to display on the demo page (owner of vaults to showcase)
NEXT_PUBLIC_DEMO_ADDRESS=0x...

# Chain ID for demo page (1337 for local, 42161 for Arbitrum)
NEXT_PUBLIC_DEMO_CHAIN_ID=1337

# ============================================
# AUTOMATION SERVICE CONNECTION
# ============================================
# URL for the automation service SSE endpoint
NEXT_PUBLIC_SSE_URL=http://your-automation-service:port/events
