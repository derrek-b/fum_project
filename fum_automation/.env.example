# FUM Automation Service Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED FOR ALL CONTEXTS
# ============================================
# Needed for production startup, full integration testing
# (`npm run start` against a local Hardhat fork), AND workflow tests
# (`npm run test:v3/v4/tj`). Anyone doing local development on this
# repo needs all of these set.

# Blockchain network ID (1337=Hardhat Arbitrum fork, 1338=Hardhat Avalanche
# fork, 42161=Arbitrum One, 43114=Avalanche C-Chain)
CHAIN_ID=1337

# WebSocket RPC endpoint for real-time events
# Local: ws://localhost:8545 (chain 1337) or ws://localhost:8546 (chain 1338)
# Production: wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
WS_URL=ws://localhost:8545

# BIP-39 mnemonic for HD wallet derivation (per-vault executor signers)
# Each vault gets a unique executor derived from this mnemonic + vault's
# executorIndex. For local Hardhat testing this MUST match DEV_MNEMONIC
# in fum/test/scripts/seed*.js, since the seed scripts fund whichever
# address gets derived from that mnemonic.
# WARNING: Never commit mnemonics to version control.
AUTOMATION_MNEMONIC=

# Port for Server-Sent Events HTTP server
SSE_PORT=3001

# Interval between retry cycles for failed vaults (milliseconds)
# 15000 (15s) for testing, 60000 (1m) for production
RETRY_INTERVAL_MS=60000

# Maximum time before a failing vault is blacklisted (milliseconds)
# 60000 (1m) for testing, 3600000 (1h) for production
MAX_FAILURE_DURATION_MS=3600000

# CoinGecko API key for token price fetching
# Required — public tier rate-limiting (~10-30 req/min shared IP) silently
# degrades strategy evaluation, VaultHealth, and Tracker accounting at scale.
COINGECKO_API_KEY=

# The Graph API key for subgraph queries (V4 pool discovery, position lookup,
# TVL). Hard-throws on missing key when V4 paths are exercised. TJ paths on
# chain 1338 don't touch The Graph, but adapter selection is per-vault so
# missing this would break any V4 flow on chain 1337.
THEGRAPH_API_KEY=

# Alchemy API key for RPC endpoints
# - Production (chain 42161/43114): RPC URL the service connects to.
# - Workflow tests: Hardhat fork upstream URL (`hardhat.config.cjs:20`) — the
#   fork pulls historical state from this on first read.
# - `npm run start` against a local fork (chain 1337/1338): NOT consumed by
#   the service itself (the fork was already started in a separate terminal),
#   but you'll want it set anyway since workflow tests share this .env.local
#   and need it.
ALCHEMY_API_KEY=

# ============================================
# REQUIRED FOR PRODUCTION ONLY
# ============================================
# Skipped automatically by `start-automation.js` when CHAIN_ID is 1337 or
# 1338 (local Hardhat fork). Safe to leave blank for local development —
# fork txs aren't indexed on Arbiscan, so the only path that uses this key
# returns no data regardless.

# Block explorer API key for V4 native-ETH fee tracking.
# Used by UniswapV4Adapter.parseCollectReceipt / parseClosureReceipt to
# query Arbiscan internal txs — that's how the V4 adapter recovers ETH
# fees, since V4 doesn't emit Collect events for native ETH. The path
# wraps the call in try/catch and degrades to null fees + warning log
# on failure, so missing this key in production with V4 vaults means
# ETH fees won't show up but the rest of the service still works.
# Get from: https://arbiscan.io/apis (works for Etherscan V2 unified API)
BLOCK_EXPLORER_API_KEY=

# ============================================
# OPTIONAL (have defaults)
# ============================================

# Fork chain selection for tests (default: arbitrum)
# - arbitrum: Uses chain 1337, port 8545, forks Arbitrum mainnet
# - avalanche: Uses chain 1338, port 8546, forks Avalanche mainnet
# FORK_CHAIN=arbitrum

# Enable verbose logging (default: false)
# DEBUG=true

# Base directory for all data files: blacklist, vault tracking, tracking failures (default: ./data)
# DATA_DIR=./data

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# Telegram notifications (both required for notifications to work)
# TELEGRAM_BOT_API_KEY=
# TELEGRAM_CHAT_ID=
