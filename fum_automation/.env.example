# FUM Automation Service Environment Variables
# Copy this file to .env.local and fill in the values

# ============================================
# REQUIRED
# ============================================

# Blockchain network ID (1337=Ganache, 42161=Arbitrum One)
CHAIN_ID=1337

# WebSocket RPC endpoint for real-time events
# Local: ws://localhost:8545
# Alchemy: wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
WS_URL=ws://localhost:8545

# Private key for the automation executor wallet
# This wallet signs transactions for vault operations
# WARNING: Never commit real private keys to version control
AUTOMATION_PRIVATE_KEY=

# Port for Server-Sent Events HTTP server
SSE_PORT=3001

# Interval between retry cycles for failed vaults (milliseconds)
# 15000 (15s) for testing, 60000 (1m) for production
RETRY_INTERVAL_MS=60000

# Maximum time before a failing vault is blacklisted (milliseconds)
# 60000 (1m) for testing, 3600000 (1h) for production
MAX_FAILURE_DURATION_MS=3600000

# The Graph API key for subgraph queries (TVL, pool age)
THEGRAPH_API_KEY=

# Alchemy API key for RPC endpoints
# Required for BOTH production and local testing
# - Production: Used for chain RPC URLs (Arbitrum, Avalanche)
# - Local testing: AlphaRouter needs real RPC for swap routing
ALCHEMY_API_KEY=

# Block explorer API key for internal transaction data
# Used for fee tracking on native ETH positions
# Get from: https://arbiscan.io/apis (works for Etherscan V2 unified API)
BLOCK_EXPLORER_API_KEY=

# ============================================
# OPTIONAL (have defaults)
# ============================================

# Fork chain selection for tests (arbitrum|avalanche)
# - arbitrum: Uses chain 1337, port 8545, forks Arbitrum mainnet
# - avalanche: Uses chain 1338, port 8546, forks Avalanche mainnet
# FORK_CHAIN=arbitrum

# Enable verbose logging (default: false)
# DEBUG=true

# Base directory for all data files: blacklist, vault tracking, tracking failures (default: ./data)
# DATA_DIR=./data

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# CoinGecko API key for token price fetching (reduces rate limiting)
# COINGECKO_API_KEY=

# Telegram notifications (both required for notifications to work)
# TELEGRAM_BOT_API_KEY=
# TELEGRAM_CHAT_ID=
