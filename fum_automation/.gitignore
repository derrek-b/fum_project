# Environment files (keep .env.example as template)
.env*
!.env.example

**/.claude/settings.local.json
node_modules

/artifacts/
/bytecode/
/dist/

# Production data files (keep directory structure with .gitkeep)
/data/*
!/data/.gitkeep
!/data/vaults/
/data/vaults/*
!/data/vaults/.gitkeep

# Test data files
/test/data/.vault-blacklist.json

cache/

# Test artifacts
test/.hardhat-state.json

# Backtest data and reports (keep directory structure with .gitkeep)
/backtest/data/*
!/backtest/data/.gitkeep
/backtest/reports/*
!/backtest/reports/.gitkeep
